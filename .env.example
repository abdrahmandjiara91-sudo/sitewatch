# UptimeNode Environment Configuration
# =====================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///data/monitor.db
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# Security Keys (auto-generated on first run, or set manually)
# SECRET_KEY=your-super-secret-key-here
# ENCRYPTION_KEY=your-encryption-key-here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
FROM_NAME=UptimeNode

# Resend API (alternative to SMTP, works on Render)
# RESEND_API_KEY=re_your_api_key_here

# Telegram Bot (optional)
# TELEGRAM_BOT_TOKEN=your-bot-token-here

# Flask/App Settings
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000
